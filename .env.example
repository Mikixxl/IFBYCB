# Supabase – Pflichtfelder (in Netlify Environment Variables eintragen)
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key

# Nur für Netlify Functions (Server-seitiger Zugriff)
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Apple CalDAV (optional – App-spezifische Passwörter nicht im .env speichern!)
# Passwörter werden verschlüsselt in der Datenbank gespeichert
